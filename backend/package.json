{
    "name": "backend",
    "version": "1.0.0",
    "description": "ExamCoach Backend – User Management & Feedback System",
    "license": "ISC",
    "author": "",
    "type": "commonjs",
    "main": "src/app.js",
    "scripts": {
        "start": "node src/app.js",
        "dev": "nodemon src/app.js",
        "test": "jest --forceExit",
        "test:coverage": "jest --coverage --forceExit",
        "format": "npx prettier --write \"**/*.{js,jsx,ts,tsx,css,scss,html}\"",
        "format:check": "npx prettier --check \"**/*.{js,jsx,ts,tsx,css,scss,html}\""
    },
    "dependencies": {
        "axios": "^1.13.5",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dev": "^0.1.3",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-jsdoc-swagger": "^1.8.0",
        "express-rate-limit": "^7.2.0",
        "express-validator": "^7.0.1",
        "helmet": "^7.2.0",
        "http-status-codes": "^2.3.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.9.3",
        "morgan": "^1.10.0",
        "multer": "^2.0.2",
        "nodemailer": "^6.9.13"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "mongodb-memory-server": "^11.0.1",
        "nodemon": "^3.1.0",
        "prettier": "3.4.2",
        "supertest": "^6.3.4"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/?(*.)+(test).js"
        ]
    }
}
